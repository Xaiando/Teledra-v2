{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://teledra.local/schemas/composition_analysis_report.schema.json",
  "title": "Teledra Composition Analysis Report",
  "description": "A diagnostic report capturing subjective or non-blocking compositional findings, separate from objective verification failures.",
  "type": "object",
  "unevaluatedProperties": false,
  "required": ["schema_version", "run_id", "score_hash", "status", "findings"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "run_id": {
      "type": "string"
    },
    "score_hash": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "status": {
      "type": "string",
      "enum": ["REVIEW", "OK"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "unevaluatedProperties": false,
        "required": ["code", "severity", "measurement"],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["INFO", "WARNING"]
          },
          "sections": {
            "type": "array",
            "items": { "type": "string" }
          },
          "measurement": {
            "type": "object",
            "unevaluatedProperties": false,
            "required": ["metric", "actual"],
            "properties": {
              "metric": {
                "type": "string"
              },
              "actual": {
                "type": ["number", "integer"]
              },
              "recommended_minimum": {
                "type": ["number", "integer"]
              },
              "recommended_maximum": {
                "type": ["number", "integer"]
              }
            }
          }
        }
      }
    }
  }
}
