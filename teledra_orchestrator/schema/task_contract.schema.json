{
  "": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "repository",
    "objective",
    "scope",
    "acceptance_criteria",
    "work_units",
    "risk",
    "budgets",
    "escalation_conditions"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "repository": {
      "type": "object",
      "required": [
        "base_commit",
        "environment_image"
      ],
      "properties": {
        "base_commit": {
          "type": "string"
        },
        "environment_image": {
          "type": "string"
        },
        "language_profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "objective": {
      "type": "object",
      "required": [
        "summary",
        "user_visible_result"
      ]
    },
    "scope": {
      "type": "object"
    },
    "assumptions": {
      "type": "array"
    },
    "acceptance_criteria": {
      "type": "array"
    },
    "work_units": {
      "type": "array"
    },
    "risk": {
      "type": "object"
    },
    "budgets": {
      "type": "object"
    },
    "escalation_conditions": {
      "type": "array"
    }
  },
  "additionalProperties": false
}