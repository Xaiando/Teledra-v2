{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gate Verdict",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "reason_code",
    "details"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REWORK",
        "REJECT",
        "ESCALATE",
        "INFRASTRUCTURE_ERROR"
      ]
    },
    "reason_code": {
      "type": "string"
    },
    "details": {
      "type": "string"
    }
  }
}